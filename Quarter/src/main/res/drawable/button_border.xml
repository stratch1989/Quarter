<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Основа - тёмный круг -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#333333" />
        </shape>
    </item>
    <!-- Радиальный блик сверху-слева -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="70%p"
                android:centerX="0.4"
                android:centerY="0.35"
                android:startColor="#8A8A8A"
                android:endColor="#3A3A3A" />
        </shape>
    </item>
    <!-- Тонкая светлая окантовка сверху -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#22FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
