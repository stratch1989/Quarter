<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Заголовок "Свой интервал" — отдельная плашка -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/custom_interval_title"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/history_popup_bg"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginBottom="8dp" />

        <!-- Контент "Повторять каждые..." — отдельная плашка -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/history_popup_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/custom_interval_repeat_every"
                android:textColor="#888888"
                android:textSize="14sp"
                android:layout_marginEnd="12dp" />

            <!-- Барабан числа -->
            <LinearLayout
                android:id="@+id/number_drum"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginEnd="8dp"
                android:clipToPadding="false"
                android:clipChildren="false">

                <TextView
                    android:id="@+id/number_prev"
                    android:layout_width="48dp"
                    android:layout_height="26dp"
                    android:textColor="#555555"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/interval_number"
                    android:layout_width="48dp"
                    android:layout_height="36dp"
                    android:background="@drawable/category_emoji_bg"
                    android:text="2"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/number_next"
                    android:layout_width="48dp"
                    android:layout_height="26dp"
                    android:textColor="#555555"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Барабан единицы -->
            <LinearLayout
                android:id="@+id/unit_drum"
                android:layout_width="68dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:clipToPadding="false"
                android:clipChildren="false">

                <TextView
                    android:id="@+id/unit_prev"
                    android:layout_width="68dp"
                    android:layout_height="26dp"
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/interval_unit"
                    android:layout_width="68dp"
                    android:layout_height="36dp"
                    android:background="@drawable/category_emoji_bg"
                    android:text="@string/custom_interval_unit_days"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/unit_next"
                    android:layout_width="68dp"
                    android:layout_height="26dp"
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Кнопка okey — поверх, справа на уровне заголовка -->
    <ImageButton
        android:id="@+id/btn_done"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:background="@android:color/transparent"
        android:src="@drawable/okey"
        android:scaleType="fitCenter"
        android:contentDescription="@string/custom_interval_done" />

</FrameLayout>
