<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/history_popup_bg"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- Отключить (скрыт по умолчанию) -->
    <LinearLayout
        android:id="@+id/menu_sub_disable"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕  Отключить"
            android:textColor="#FF5252"
            android:textSize="17sp" />

    </LinearLayout>

    <View
        android:id="@+id/divider_disable"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="#3A3A3C"
        android:visibility="gone" />

    <!-- Ежедневная -->
    <LinearLayout
        android:id="@+id/menu_sub_daily"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/text_sub_daily"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅  Ежедневная"
            android:textColor="#FFFFFF"
            android:textSize="17sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="#3A3A3C" />

    <!-- Еженедельная -->
    <LinearLayout
        android:id="@+id/menu_sub_weekly"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/text_sub_weekly"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📆  Еженедельная"
            android:textColor="#FFFFFF"
            android:textSize="17sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="#3A3A3C" />

    <!-- Месячная -->
    <LinearLayout
        android:id="@+id/menu_sub_monthly"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/text_sub_monthly"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗓️  Месячная"
            android:textColor="#FFFFFF"
            android:textSize="17sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="#3A3A3C" />

    <!-- Свой интервал -->
    <LinearLayout
        android:id="@+id/menu_sub_custom"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️  Свой интервал"
            android:textColor="#FFFFFF"
            android:textSize="17sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="#3A3A3C" />

    <!-- Текущие подписки -->
    <LinearLayout
        android:id="@+id/menu_sub_list"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋  Текущие подписки"
            android:textColor="#FFFFFF"
            android:textSize="17sp" />

    </LinearLayout>

</LinearLayout>
