<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/history_popup_bg"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- Отключить (скрыт по умолчанию) -->
    <LinearLayout
        android:id="@+id/menu_sub_disable"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_disable_5"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sub_menu_disable"
            android:textColor="#FF5252"
            android:textSize="17sp" />

    </LinearLayout>

    <View
        android:id="@+id/divider_disable"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="#3A3A3C"
        android:visibility="gone" />

    <!-- Ежедневная -->
    <LinearLayout
        android:id="@+id/menu_sub_daily"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_daily_cal1"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/text_sub_daily"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sub_menu_daily"
            android:textColor="#FFFFFF"
            android:textSize="17sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="#3A3A3C" />

    <!-- Еженедельная -->
    <LinearLayout
        android:id="@+id/menu_sub_weekly"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_weekly_cal7"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/text_sub_weekly"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sub_menu_weekly"
            android:textColor="#FFFFFF"
            android:textSize="17sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="#3A3A3C" />

    <!-- Месячная -->
    <LinearLayout
        android:id="@+id/menu_sub_monthly"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_monthly_5"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/text_sub_monthly"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sub_menu_monthly"
            android:textColor="#FFFFFF"
            android:textSize="17sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="#3A3A3C" />

    <!-- Свой интервал -->
    <LinearLayout
        android:id="@+id/menu_sub_custom"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_custom_5"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sub_menu_custom"
            android:textColor="#FFFFFF"
            android:textSize="17sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="#3A3A3C" />

    <!-- Текущие подписки -->
    <LinearLayout
        android:id="@+id/menu_sub_list"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_sublist_2"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sub_menu_list"
            android:textColor="#FFFFFF"
            android:textSize="17sp" />

    </LinearLayout>

</LinearLayout>
