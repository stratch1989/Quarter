<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal">

    <!-- Заголовок с кнопкой okey в одном ряду -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/history_popup_bg"
        android:paddingStart="20dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Время"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_time_done"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@drawable/okey"
            android:scaleType="fitCenter"
            android:contentDescription="Готово" />

    </LinearLayout>

    <!-- Контент — часы : минуты — барабаны -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/history_popup_bg"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Барабан часов -->
        <LinearLayout
            android:id="@+id/hour_drum"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:clipToPadding="false"
            android:clipChildren="false">

            <TextView
                android:id="@+id/hour_prev"
                android:layout_width="48dp"
                android:layout_height="26dp"
                android:textColor="#555555"
                android:textSize="13sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/hour_value"
                android:layout_width="48dp"
                android:layout_height="36dp"
                android:background="@drawable/category_emoji_bg"
                android:text="14"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/hour_next"
                android:layout_width="48dp"
                android:layout_height="26dp"
                android:textColor="#555555"
                android:textSize="13sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Разделитель ":" -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textColor="#888888"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:gravity="center" />

        <!-- Барабан минут -->
        <LinearLayout
            android:id="@+id/minute_drum"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:clipToPadding="false"
            android:clipChildren="false">

            <TextView
                android:id="@+id/minute_prev"
                android:layout_width="48dp"
                android:layout_height="26dp"
                android:textColor="#555555"
                android:textSize="13sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/minute_value"
                android:layout_width="48dp"
                android:layout_height="36dp"
                android:background="@drawable/category_emoji_bg"
                android:text="30"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/minute_next"
                android:layout_width="48dp"
                android:layout_height="26dp"
                android:textColor="#555555"
                android:textSize="13sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
