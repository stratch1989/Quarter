<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/clickable_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B3000000"
    android:clickable="true"
    android:gravity="center"
    tools:context=".EveryDayQuestion">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/frameForMetrics"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:background="@drawable/dialog_bg"
            android:foreground="@drawable/dialog_border"
            android:clipToOutline="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="24dp">

                <ImageView
                    android:id="@+id/imageView2"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ico_for_quest"
                    android:importantForAccessibility="no" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/edq_wow"
                    android:textColor="@android:color/background_light"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="8dp" />

                <TextView
                    android:id="@+id/day_limit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/edq_saved_yesterday"
                    android:textColor="@android:color/background_light"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/edq_decide_what_to_do"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

                <FrameLayout
                    android:id="@+id/option1"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/button_border7"
                    android:clickable="true">

                    <TextView
                        android:id="@+id/text1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/edq_option_spend_all"
                        android:textColor="#fea00a"
                        android:textSize="16sp" />
                </FrameLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="10dp" />

                <FrameLayout
                    android:id="@+id/option2"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/button_border7"
                    android:clickable="true">

                    <TextView
                        android:id="@+id/text2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/edq_option_increase_budget"
                        android:textColor="#fea00a"
                        android:textSize="16sp" />
                </FrameLayout>

            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
