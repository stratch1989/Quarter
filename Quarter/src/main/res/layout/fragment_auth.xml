<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/clickable_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E1000000"
    android:clickable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <LinearLayout
            android:background="@drawable/rounded_corners2"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/auth_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auth_title"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <EditText
                android:id="@+id/email_input"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:backgroundTint="#555555"
                android:textSize="16sp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/password_input"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/auth_hint_password"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:backgroundTint="#555555"
                android:textSize="16sp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/confirm_password_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/confirm_password_input"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/auth_hint_confirm_password"
                    android:inputType="textPassword"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:backgroundTint="#555555"
                    android:textSize="16sp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:layout_marginBottom="12dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/error_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF5252"
                android:textSize="13sp"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/auth_button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/auth_button_sign_in"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9800"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/google_sign_in_button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/auth_button_google"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4285F4"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/toggle_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auth_toggle_register"
                android:textColor="#FF9800"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <!-- Показываем когда пользователь уже залогинен -->
            <LinearLayout
                android:id="@+id/logged_in_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/user_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/sign_out_button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/auth_button_sign_out"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#555555" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
