<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/clickable_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B3000000"
    android:clickable="true"
    tools:context=".History">

    <!-- Весь контент попапа: заголовок + основной блок -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:orientation="vertical">

        <!-- Заголовок — отдельная плашка -->
        <TextView
            android:id="@+id/historyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/history_popup_bg"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="@string/history_title"
            android:textColor="@android:color/white"
            android:textSize="17sp" />

        <!-- Основной блок попапа 280x280 -->
        <FrameLayout
            android:id="@+id/frameForMetrics"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:background="@drawable/history_popup_bg"
            android:clipToOutline="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/periodTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="#8E8E93"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-light"
                    android:visibility="gone" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="4dp"
                    android:background="#3A3A3C" />

                <TextView
                    android:id="@+id/emptyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:text="@string/history_empty"
                    android:textColor="@android:color/darker_gray"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/historyRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ScrollView
                    android:id="@+id/chartContainer"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:visibility="gone">

                    <com.example.quarter.android.DonutChartView
                        android:id="@+id/donutChart"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </ScrollView>

            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <!-- Кнопки режимов: вертикально справа от попапа -->
    <!-- marginStart = 16dp (отступ контента) + 280dp (ширина попапа) + 4dp (gap) = 300dp -->
    <LinearLayout
        android:id="@+id/modeToggle"
        android:layout_width="42dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="300dp"
        android:layout_marginTop="172dp"
        android:background="@drawable/category_emoji_bg"
        android:clipToOutline="true"
        android:orientation="vertical">

        <TextView
            android:id="@+id/listModeButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="#252525"
            android:gravity="center"
            android:text="☰"
            android:textColor="@android:color/white"
            android:textSize="20sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#333333" />

        <FrameLayout
            android:id="@+id/categoryFilterButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_grid_4" />

        </FrameLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#333333" />

        <TextView
            android:id="@+id/chartModeButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center"
            android:text="◎"
            android:textColor="@android:color/white"
            android:textSize="26sp" />

    </LinearLayout>

    <!-- Кнопки −/+ снизу от попапа -->
    <!-- marginTop = 4dp (marginTop контента) + ~40dp (заголовок) + 8dp (gap) + 280dp (попап) + 4dp (gap) = 336dp -->
    <LinearLayout
        android:id="@+id/typeToggle"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="196dp"
        android:layout_marginTop="336dp"
        android:background="@drawable/category_emoji_bg"
        android:clipToOutline="true"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/expenseButton"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:background="#252525"
            android:gravity="center"
            android:text="−"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0.5dp"
            android:layout_height="match_parent"
            android:background="#333333" />

        <TextView
            android:id="@+id/incomeButton"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="+"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Кнопка редактирования (карандаш) — правый верхний угол -->
    <ImageButton
        android:id="@+id/editButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="258dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/circle_button_bg"
        android:contentDescription="@string/cd_edit"
        android:padding="8dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_edit"
        android:visibility="visible" />

    <!-- Кнопка подтверждения (okey) — на том же месте, скрыта по умолчанию -->
    <ImageButton
        android:id="@+id/confirmButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="258dp"
        android:layout_marginTop="4dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/cd_edit"
        android:scaleType="fitCenter"
        android:src="@drawable/okey"
        android:visibility="gone" />

</FrameLayout>
