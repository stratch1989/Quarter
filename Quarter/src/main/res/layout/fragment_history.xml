<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/clickable_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B3000000"
    android:clickable="true"
    tools:context=".History">

    <FrameLayout
        android:id="@+id/frameForMetrics"
        android:layout_width="308dp"
        android:layout_height="308dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/history_popup_bg"
        android:clipToOutline="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"
            android:paddingTop="26dp"
            android:paddingBottom="26dp">

            <TextView
                android:id="@+id/historyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="История трат"
                android:textColor="@android:color/white"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/periodTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#fea00a"
                android:textSize="13sp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="4dp"
                android:background="#3A3A3C" />

            <TextView
                android:id="@+id/emptyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="Траты за текущий период\nпоявятся здесь"
                android:textColor="@android:color/darker_gray"
                android:textSize="14sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/historyRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ScrollView
                android:id="@+id/chartContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:visibility="gone">

                <com.example.quarter.android.DonutChartView
                    android:id="@+id/donutChart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </ScrollView>

        </LinearLayout>
    </FrameLayout>

    <!-- Кнопки режимов: вертикально справа от попапа, по центру -->
    <LinearLayout
        android:id="@+id/modeToggle"
        android:layout_width="42dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="328dp"
        android:layout_marginTop="88dp"
        android:background="@drawable/category_emoji_bg"
        android:clipToOutline="true"
        android:orientation="vertical">

        <TextView
            android:id="@+id/listModeButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:background="#252525"
            android:gravity="center"
            android:text="☰"
            android:textColor="@android:color/white"
            android:textSize="20sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#333333" />

        <TextView
            android:id="@+id/categoryFilterButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center"
            android:text="📊"
            android:textSize="18sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#333333" />

        <TextView
            android:id="@+id/chartModeButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center"
            android:text="◎"
            android:textColor="@android:color/white"
            android:textSize="22sp" />

    </LinearLayout>

    <!-- Кнопки - / + снизу от попапа -->
    <LinearLayout
        android:id="@+id/typeToggle"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="16dp"
        android:layout_marginTop="316dp"
        android:background="@drawable/category_emoji_bg"
        android:clipToOutline="true"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/expenseButton"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:background="#252525"
            android:gravity="center"
            android:text="−"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0.5dp"
            android:layout_height="match_parent"
            android:background="#333333" />

        <TextView
            android:id="@+id/incomeButton"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="+"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>
</FrameLayout>
