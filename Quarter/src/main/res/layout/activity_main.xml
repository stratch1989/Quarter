<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/testet"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">


                <Button
                    android:id="@+id/button7"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_margin="0dp"
                    android:layout_weight="0"
                    android:background="@drawable/button_border"
                    android:padding="0dp"
                    android:text="7"
                    android:textSize="35sp" />

                <Button
                    android:id="@+id/button8"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_margin="0dp"
                    android:layout_weight="0"
                    android:background="@drawable/button_border"
                    android:padding="0dp"
                    android:text="8"
                    android:textSize="35sp" />

                <Button
                    android:id="@+id/button9"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_margin="0dp"
                    android:layout_weight="0"
                    android:background="@drawable/button_border"
                    android:padding="0dp"
                    android:text="9"
                    android:textSize="35sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button4"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_margin="0dp"
                    android:layout_weight="0"
                    android:background="@drawable/button_border"
                    android:padding="0dp"
                    android:text="4"
                    android:textSize="35sp" />

                <Button
                    android:id="@+id/button5"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_margin="0dp"
                    android:layout_weight="0"
                    android:background="@drawable/button_border"
                    android:padding="0dp"
                    android:text="5"
                    android:textSize="35sp" />

                <Button
                    android:id="@+id/button6"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_margin="0dp"
                    android:layout_weight="0"
                    android:background="@drawable/button_border"
                    android:padding="0dp"
                    android:text="6"
                    android:textSize="35sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button1"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_margin="0dp"
                    android:layout_weight="0"
                    android:background="@drawable/button_border"
                    android:padding="0dp"
                    android:text="1"
                    android:textSize="35sp" />

                <Button
                    android:id="@+id/button2"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_margin="0dp"
                    android:layout_weight="0"
                    android:background="@drawable/button_border"
                    android:padding="0dp"
                    android:text="2"
                    android:textSize="35sp" />

                <Button
                    android:id="@+id/button3"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_margin="0dp"
                    android:layout_weight="0"
                    android:background="@drawable/button_border"
                    android:padding="0dp"
                    android:text="3"
                    android:textSize="35sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/button_plus_minus"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_margin="0dp"
                    android:layout_weight="0"
                    android:background="@drawable/button_border"
                    android:padding="0dp"
                    android:text="⁺∕₋"
                    android:textSize="25sp"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/button0"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_margin="0dp"
                    android:layout_weight="0"
                    android:background="@drawable/button_border"
                    android:padding="0dp"
                    android:text="0"
                    android:textSize="35sp" />

                <Button
                    android:id="@+id/button_point"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_margin="0dp"
                    android:layout_weight="0"
                    android:background="@drawable/button_border"
                    android:padding="0dp"
                    android:text="."
                    android:textSize="35sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/button_del"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_margin="0dp"
                android:background="@drawable/button_border2"
                android:padding="28dp"
                android:src="@drawable/ic_backspace"
                android:scaleType="fitCenter"
                android:contentDescription="Удалить" />

            <ImageButton
                android:id="@+id/button_undo"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_margin="0dp"
                android:background="@drawable/button_border2"
                android:padding="28dp"
                android:src="@drawable/ic_undo"
                android:scaleType="fitCenter"
                android:contentDescription="Отменить" />

            <Button
                android:id="@+id/button_enter"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_margin="0dp"
                android:layout_weight="2"
                android:background="@drawable/button_border2"
                android:padding="0dp"
                android:text="↵"
                android:textSize="40sp" />

        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/result"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        android:fontFamily="@font/bebas_neue"
        android:text="0"
        android:textAppearance="@style/TextAppearance.AppCompat.Display4"
        android:textColor="@android:color/background_light"
        android:textSize="70sp"
        android:textStyle="bold"
        android:layout_marginStart="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.013"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <TextView
        android:id="@+id/last_operation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"
        android:textColor="#888888"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@+id/value"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="5dp"
        android:text="0"
        android:textAppearance="@style/TextAppearance.AppCompat.Display4"
        android:textColor="@android:color/background_light"
        android:textSize="60sp"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/settings"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/circle_button_bg"
        android:src="@drawable/ic_settings"
        android:scaleType="centerInside"
        android:padding="8dp"
        android:contentDescription="Настройки"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/history"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/circle_button_bg"
        android:src="@drawable/ic_history"
        android:scaleType="centerInside"
        android:padding="8dp"
        android:contentDescription="История"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/average"
        android:text="На сегодня"
        android:textColor="#FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/result" />

    <TextView
        android:id="@+id/day_limit"
        android:layout_width="268dp"
        android:layout_height="33dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="16dp"
        android:text="Введите дату и сумму в настройках"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView2" />

    <FrameLayout
        android:id="@+id/place_holder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</androidx.constraintlayout.widget.ConstraintLayout>